FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    docker.io \
    git \
    g++ \
    make \
    python3 \
    && rm -rf /var/lib/apt/lists/*

COPY scripts/docker-compose-entrypoint.sh /usr/local/bin/nanoclaw-compose-entrypoint.sh
RUN chmod +x /usr/local/bin/nanoclaw-compose-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/nanoclaw-compose-entrypoint.sh"]
