# ─── Alerta Invest Social Pipeline ───────────────────────────────────────────
# Add these to your project root .env file

# Flago / Alerta Invest API
FLAGO_API_URL=https://api.alertainvest.com    # URL of the Flago signals endpoint
FLAGO_API_KEY=                                # API key if required

# Brand landing page (used in ads CTAs)
ALERTA_INVEST_URL=https://alertainvest.com

# ─── Meta (Instagram + Facebook Ads) ─────────────────────────────────────────
META_ACCESS_TOKEN=                            # Long-lived user access token
INSTAGRAM_BUSINESS_ACCOUNT_ID=               # Instagram Business Account ID
META_PAGE_ID=                                 # Facebook Page ID linked to Instagram
META_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXXXXX     # Ad Account ID (must start with act_)

# ─── X / Twitter ──────────────────────────────────────────────────────────────
X_API_KEY=                                    # API Key (Consumer Key)
X_API_SECRET=                                 # API Secret (Consumer Secret)
X_ACCESS_TOKEN=                               # User Access Token
X_ACCESS_SECRET=                              # User Access Token Secret
X_BEARER_TOKEN=                               # Bearer Token (for analytics read)
X_USER_ID=                                    # Numeric User ID
X_AD_ACCOUNT_ID=                              # Ads Account ID
X_FUNDING_INSTRUMENT_ID=                      # Funding instrument ID for X Ads

# ─── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=                          # TikTok for Developers access token
TIKTOK_USERNAME=                              # TikTok @username (without @)
TIKTOK_ADVERTISER_ID=                         # TikTok Ads advertiser ID

# ─── YouTube / Google Ads ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=                              # YouTube Data API v3 key
YOUTUBE_CHANNEL_ID=                           # Your YouTube Channel ID
YOUTUBE_OAUTH_TOKEN=                          # OAuth 2.0 token (for upload + analytics)
GOOGLE_ADS_DEVELOPER_TOKEN=                   # Google Ads developer token
GOOGLE_ADS_CUSTOMER_ID=                       # Google Ads customer ID (XXX-XXX-XXXX)
GOOGLE_ADS_OAUTH_TOKEN=                       # OAuth 2.0 token for Google Ads
GOOGLE_ADS_LOGIN_CUSTOMER_ID=                 # MCC account ID (if using manager account)

# ─── Reddit ───────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=                             # Reddit app client ID (for posting)
REDDIT_CLIENT_SECRET=                         # Reddit app client secret
REDDIT_USERNAME=                              # Reddit username
REDDIT_PASSWORD=                              # Reddit password
REDDIT_ADS_CLIENT_ID=                         # Reddit Ads API client ID (may differ)
REDDIT_ADS_CLIENT_SECRET=                     # Reddit Ads API client secret
REDDIT_ADS_ACCOUNT_ID=                        # Reddit Ads account ID

# ─── Cloudinary (image hosting for Meta/TikTok/Reddit) ───────────────────────
CLOUDINARY_CLOUD_NAME=                        # Cloudinary cloud name
CLOUDINARY_API_KEY=                           # Cloudinary API key
CLOUDINARY_API_SECRET=                        # Cloudinary API secret
